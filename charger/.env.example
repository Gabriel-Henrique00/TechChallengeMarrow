# ─────────────────────────────────────────────
# Banco de dados (MySQL)
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=admin
DB_PASS=admin
DB_NAME=charger_db

# ─────────────────────────────────────────────
# Autenticação JWT
# ─────────────────────────────────────────────
JWT_SECRET=super-senha-mega-secreta
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# Pluggy – Iniciação de Pagamento (Open Finance)
# Obtenha em: https://dashboard.pluggy.ai
# ─────────────────────────────────────────────
PLUGGY_CLIENT_ID=seu-client-id-aqui
PLUGGY_CLIENT_SECRET=seu-client-secret-aqui

# ID da conta recebedora cadastrada na Pluggy
PLUGGY_RECIPIENT_ID=uuid-da-conta-recebedora

# Segredo para validar assinaturas dos webhooks enviados pela Pluggy
PLUGGY_WEBHOOK_SECRET=segredo-do-webhook-pluggy

# ─────────────────────────────────────────────
# URLs da aplicação
# ─────────────────────────────────────────────
# URL base do backend (usada internamente)
APP_BASE_URL=http://localhost:3000

# URL do frontend (usada nos callbackUrls enviados à Pluggy)
# Em desenvolvimento local, use ngrok ou similar para expor o frontend:
#   npx ngrok http 3001  →  copie a URL https gerada aqui
FRONTEND_URL=http://localhost:3001